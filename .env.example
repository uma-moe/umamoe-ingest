# Copy to .env and fill in your values

# Shared Postgres DB (same connection string as the main backend)
DATABASE_URL=postgres://user:password@localhost:5432/umamoe

# Must match JWT_SECRET in the main backend — tokens issued there are verified here
JWT_SECRET=change-me-to-a-long-random-secret

# Server bind address (Apache proxies api.uma.moe → this port)
HOST=127.0.0.1
PORT=3003
